		annotation SummarizationSetBy = Automatic

	/// Date portion of the receipt event timestamp. Used for the dim_date relationship (Direct Lake requires matching column types, so this date column relates to dim_date[Date] instead of the timestamp).
	column 'Event Date'
		dataType: dateTime
		formatString: Short Date
		lineageTag: a1a1a1a1-0000-0000-0000-000000000011
		sourceLineageTag: event_date
		summarizeBy: none
		sourceColumn: event_date

		annotation SummarizationSetBy = Automatic

